# EditorConfig — https://editorconfig.org
# Maintains consistent coding styles across editors and IDEs

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{py,pyi}]
indent_size = 4
max_line_length = 120

[*.{ts,tsx,js,jsx,vue,json,jsonc,yml,yaml}]
indent_size = 2

[*.{md,mdx}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{sh,bash}]
indent_size = 2
