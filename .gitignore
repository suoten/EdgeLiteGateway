# ============================================
# EdgeLiteGateway .gitignore
# ============================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.venv/
venv/
env/

# ---------- Python 测试/覆盖率 ----------
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# ---------- Cython编译产物 ----------
*.so
*.pyd
src/edgelite/_cython/*.c

# ---------- 前端 ----------
node_modules/
web/dist/

# ---------- 配置与敏感文件 ----------
configs/config.yaml
configs/config.local.yaml
.env
.env.*
!.env.example
!docker/.env.example
!web/.env.example
*.pem
*.key
*.cert

# ---------- 运行时数据 ----------
# data/ 目录包含所有运行时数据库、日志、备份和测试输出文件
# 测试输出文件（pytest_*.txt, pytest_*.xml, co_err.txt 等）不应提交到版本控制
data/
.initial_admin_password  # FIXED-P0: 明文初始管理员密码文件，禁止提交
!web/src/views/data/
logs/
backups/
*.db
*.db-journal
*.db-wal
*.db-shm
# 额外保护：即使 data/ 规则被移除，测试输出文件仍被忽略
data/pytest_*.xml
data/co_err.txt

# ---------- Docker运行时 ----------
docker/data/

# ---------- IDE ----------
.idea/
.vscode/
.arts/
.codeartsdoer/
.jlsp/
.preferences/
.project-meta/
*.swp
*.swo
*~

# ---------- Cursor ----------
.cursorignore

# ---------- 操作系统 ----------
.DS_Store
Thumbs.db
Desktop.ini

# ---------- 构建工具 ----------
.ruff_cache/

# ---------- 开发工具/临时文件 ----------
test_result*.txt
demo.gif
demo.tape
gen_demo_gif_pure.py
web/public/gen_demo_gif.html

# ---------- 打包文件 ----------
*.zip
*.tar.gz
*.tar.bz2

# ---------- 推广文章与截图 ----------
docs/articles/
docs/images/

# ---------- 一次性修复脚本 ----------
scripts/fix_api_detail.py

# ---------- API 契约校验临时产物 ----------
scripts/contract_report.json

# ---------- 验证/测试临时文件 ----------
_*.py
_*.txt
_*.err
_*.log
_*.xml
pyright_*.log
pyright_*.json
pyright_*.txt
pytest_*.txt
test_*.txt
test_full_output*.txt
test_smoke_output.txt
test_stdout.txt
test_all*.txt
test_result*.txt
test_minimal_sqlite.py
test_storage_smoke.py
test_ts_debug*.py
test_write.py
test_api.py
test_core.py
test_patch.py
run_test_patch.py
.read_helper.py
failed_tests.txt
fix_test.txt
notif_part*.txt
cov_baseline.txt
test_reports_test/

# ---------- 引擎/工具内部文件 ----------
.loopengine/
.ab-home/
.trae/
.convergeloop/
fix_bom.py
count_docstrings.py
parse_results.py
fix_rbac.py
fix_typo.py
report.md
FIX_PROMPTS.md
.uploads/

# ---------- 发布前清理追加 (P2) ----------
*.tmp
debug.log
*.pyc
__pycache__/
.env.local
test_screenshots/
test_screenshots_v2/
audit_i18n_report.json
fix_north_adapters.py
coverage_*.json
cov_*.txt
# FIXED: 允许 coverage.xml 提交到仓库，供 DevOps 扫描器检测测试覆盖率
# 其他覆盖率产物仍被忽略
!coverage.xml
.git_commit_msg.txt

# ---------- 运行时报告/审计产物（不应纳入版本控制） ----------
audit_reports/
edgelite-bugfix-report/
reports/*.json
smoke_test_results.xml

# ConvergeLoop 自动补充（防止 git add -A 卡死）
site-packages/
.tox/
.eggs/
.next/
.nuxt/
.output/
vendor/
target/
*.dll
*.dylib
*.exe
*.bin
.convergeloop/
