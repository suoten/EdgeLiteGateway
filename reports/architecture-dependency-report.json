{
  "project": "EdgeLite Gateway",
  "version": "1.0.0",
  "analysis_date": "2026-07-18",
  "layers": {
    "api": {
      "path": "src/edgelite/api/",
      "depends_on": ["services", "security", "config", "error_codes"],
      "forbidden_imports": [],
      "violations": 0,
      "status": "compliant"
    },
    "services": {
      "path": "src/edgelite/services/",
      "depends_on": ["storage", "drivers", "engine", "security", "config", "error_codes"],
      "forbidden_imports": [],
      "violations": 0,
      "status": "compliant"
    },
    "drivers": {
      "path": "src/edgelite/drivers/",
      "depends_on": ["engine", "storage", "security", "config", "error_codes", "packet_recorder"],
      "forbidden_imports": ["api"],
      "violations": 0,
      "status": "compliant"
    },
    "engine": {
      "path": "src/edgelite/engine/",
      "depends_on": ["storage", "config", "error_codes", "packet_recorder"],
      "forbidden_imports": ["api"],
      "violations": 0,
      "status": "compliant"
    },
    "storage": {
      "path": "src/edgelite/storage/",
      "depends_on": ["config", "error_codes"],
      "forbidden_imports": ["api", "services"],
      "violations": 0,
      "status": "compliant"
    },
    "security": {
      "path": "src/edgelite/security/",
      "depends_on": ["config", "error_codes"],
      "forbidden_imports": ["api"],
      "violations": 0,
      "status": "compliant"
    }
  },
  "neutral_modules": [
    "src/edgelite/error_codes.py",
    "src/edgelite/packet_recorder.py",
    "src/edgelite/config.py",
    "src/edgelite/constants.py"
  ],
  "dependency_rules": {
    "description": "分层依赖规则：上层可依赖下层，下层不可依赖上层",
    "rules": [
      "api → services → storage",
      "api → services → drivers → engine → storage",
      "security (独立模块，被各层引用)",
      "config (独立模块，被各层引用)",
      "error_codes (中立模块，消除跨层依赖)",
      "packet_recorder (中立模块，消除Engine→API跨层依赖)"
    ]
  },
  "total_violations": 0,
  "compliance_score": 100,
  "check_command": "python scripts/check_architecture.py"
}
