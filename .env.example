# EdgeLiteGateway v1.0 Community - 环境变量配置示例
# 复制此文件为 .env 并修改配置值
# cp .env.example .env
# 格式：EDGELITE_<SECTION>__<KEY>（双下划线分隔 section 和 key）

# ============================================
# 核心服务配置
# Docker 部署请使用 0.0.0.0，本地开发可使用 127.0.0.1
# ============================================
EDGELITE_SERVER__HOST=0.0.0.0
EDGELITE_SERVER__PORT=8080
# CORS 跨域配置（多个来源用分号分隔）
# 10#修复: 使用推荐字段名 cors_allowed_origins（旧字段 cors_origins 仅作向后兼容读取）
EDGELITE_SERVER__CORS_ALLOWED_ORIGINS=http://localhost:5173;http://localhost:3000;http://localhost:8180

# ============================================
# 数据库配置
# ============================================
EDGELITE_DATABASE__SQLITE_PATH=data/edgelite.db
# FIXED-P1: 补全连接池配置项（PostgreSQL/MySQL 后端时生效，SQLite 忽略）
# EDGELITE_DATABASE__POOL_SIZE=10
# EDGELITE_DATABASE__MAX_OVERFLOW=20
# EDGELITE_DATABASE__POOL_RECYCLE=3600
# EDGELITE_DATABASE__POOL_TIMEOUT=30
# WebSocket 最大并发连接数（防止连接耗尽 DoS）
# EDGELITE_SERVER__WS_MAX_CONNECTIONS=200

# ============================================
# 管理员密码配置
# 首次启动时设置admin密码，仅在创建admin用户时生效
# 若未配置，系统将自动生成随机密码并写入 data/.initial_admin_password
# 如需重置已忘记的密码，同时设置以下两个变量并重启：
#   EDGELITE_ADMIN_PASSWORD=新密码
#   EDGELITE_RESET_ADMIN_PASSWORD=true
# 重置成功后建议将 EDGELITE_RESET_ADMIN_PASSWORD 删除或注释掉
# ============================================
# EDGELITE_ADMIN_PASSWORD=<your-admin-password>
# EDGELITE_RESET_ADMIN_PASSWORD=true

# ============================================
# InfluxDB 时序数据库
# 必须配置！否则时序数据存储功能不可用
# 生成 Token 命令: python -c "import secrets; print(secrets.token_urlsafe(48))"
# ============================================
EDGELITE_INFLUXDB__URL=http://localhost:8086
EDGELITE_INFLUXDB__TOKEN=<your-influxdb-token-here>
EDGELITE_INFLUXDB__ORG=edgelite
EDGELITE_INFLUXDB__BUCKET=edgelite

# ============================================
# MQTT 配置
# ============================================
EDGELITE_MQTT__BROKER=localhost
EDGELITE_MQTT__PORT=1883
# EDGELITE_MQTT__USERNAME=
# EDGELITE_MQTT__PASSWORD=

# ============================================
# 安全配置（必须配置！否则服务无法启动）
# 生成命令: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ============================================
EDGELITE_SECURITY__SECRET_KEY=<your-secret-key-here>
# EDGELITE_SECURITY__ACCESS_TOKEN_EXPIRE_MINUTES=30
# EDGELITE_SECURITY__REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# CSRF 密钥（生产环境强烈建议配置！）
# FIXED: 补全 example 缺失的 EDGELITE_CSRF_SECRET 文档 [2026-06-29]
# 未配置时中间件自动生成随机值（重启后 CSRF token 失效，前端表单需重新加载）
# 生产环境若配置为已知不安全默认值/占位符将拒绝启动；长度建议 >= 32 字符
# 生成命令: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ============================================
EDGELITE_CSRF_SECRET=<your-csrf-secret-at-least-32-chars>

# ============================================
# 加密与密钥配置（生产环境必填！缺失将拒绝启动）
# 用于敏感凭据加密（Fernet/AES-GCM）的密钥派生
# ============================================
# 主密钥：用于派生 Fernet 加密密钥，未配置时生产环境将拒绝启动
# 生成命令: openssl rand -hex 32
#        或 python -c "import secrets; print(secrets.token_hex(32))"
EDGELITE_MASTER_KEY=<your-master-key-hex-32>
# KDF 盐值：base64 编码的 16 字节随机值，用于 PBKDF2 密钥派生
# 生成命令: python -c "import base64,os; print(base64.b64encode(os.urandom(16)).decode())"
EDGELITE_KDF_SALT=<your-base64-kdf-salt>
# 允许不安全 TLS（cert_reqs=none）：仅用于自签名证书测试环境，生产环境切勿启用
# EDGELITE_ALLOW_INSECURE_TLS=0

# ============================================
# 可选服务开关
# ============================================
# EDGELITE_SIMULATOR__AUTO_CREATE=true
# EDGELITE_PREPROCESS__ENABLED=false
# EDGELITE_MQTT_SERVER__ENABLED=false
# EDGELITE_MODBUS_SLAVE__ENABLED=false
# EDGELITE_SERIAL_BRIDGE__ENABLED=false
# EDGELITE_GRAFANA__ENABLED=false
# EDGELITE_GRAFANA__URL=http://localhost:3001
# EDGELITE_MCP_SERVER__ENABLED=false
# EDGELITE_OTA_UPDATE_URL=
# EDGELITE_SERVER__DEBUG_API_ENABLED=false
# EDGELITE_SERVER__WEBHOOK_API_KEY=

# ============================================
# AI推理引擎配置
# 默认启用，需安装 onnxruntime: pip install ".[ai]"
# ============================================
# EDGELITE_AI_INFERENCE__ENABLED=true
# EDGELITE_AI_INFERENCE__MODELS_DIR=

# ============================================
# 视频服务配置
# ============================================
# EDGELITE_VIDEO__PYGBSENTRY__ENDPOINT=
# EDGELITE_VIDEO__PYGBSENTRY__API_KEY=

# ============================================
# 日志配置
# ============================================
EDGELITE_LOGGING__LEVEL=INFO

# ============================================
# 开发模式开关（生产环境必须为 false）
# DEV_MODE=true 时：跳过主密钥强制校验、启用宽松CORS、Cookie secure=False
# 生产环境设为 false 时：强制校验 MASTER_KEY/KDF_SALT、收紧安全策略
# ============================================
DEV_MODE=false

# ============================================
# 管理员用户名配置
# 默认 admin，可自定义初始管理员用户名
# ============================================
# EDGELITE_ADMIN_USERNAME=admin

# ============================================
# 配置文件路径覆盖
# 默认 configs/config.yaml，可指向自定义路径
# ============================================
# EDGELITE_CONFIG=configs/config.yaml

# ============================================
# 数据目录覆盖
# 默认 data/，可指向自定义路径
# ============================================
# EDGELITE_DATA_DIR=data

# ============================================
# 前端构建产物目录
# Docker 部署时由 Dockerfile 设置，本地开发可指向 web/dist
# ============================================
# EDGELITE_FRONTEND_DIST=

# ============================================
# 前端基础 URL（用于 CORS/重定向配置）
# ============================================
# EDGELITE_FRONTEND_URL=http://localhost:5173

# ============================================
# 启动时一致性校验开关
# 默认 true，生产环境建议保持开启
# ============================================
# EDGELITE_CHECK_CONSISTENCY=true

# ============================================
# 速率限制后端配置
# memory: 内存限流（单实例），redis: Redis 限流（多实例部署）
# ============================================
# EDGELITE_RATE_LIMIT_BACKEND=memory
# EDGELITE_RATE_LIMIT_REDIS_URL=redis://localhost:6379/0

# ============================================
# Alembic 数据库迁移 URL 覆盖
# 默认使用 DATABASE__SQLITE_PATH 推导，PostgreSQL/MySQL 时需单独配置
# ============================================
# ALEMBIC_DATABASE_URL=

# ============================================
# 测试脚本配置（仅用于自动化测试）
# ============================================
# EDGELITE_TEST_BASE=http://127.0.0.1:8080
# EDGELITE_TEST_USER=admin
# EDGELITE_TEST_PASS=
# TEST_WEBHOOK_TOKEN=
