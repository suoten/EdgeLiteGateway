# EdgeLiteGateway v1.0 Community - 环境变量配置示例
# 复制此文件为 .env 并修改配置值
# cp .env.example .env
# 格式：EDGELITE_<SECTION>__<KEY>（双下划线分隔 section 和 key）

# ============================================
# 核心服务配置
# Docker 部署请使用 0.0.0.0，本地开发可使用 127.0.0.1
# ============================================
EDGELITE_SERVER__HOST=0.0.0.0
EDGELITE_SERVER__PORT=8080
# CORS 跨域配置（多个来源用逗号分隔）
EDGELITE_SERVER__CORS_ORIGINS=http://localhost:3000

# ============================================
# 数据库配置
# ============================================
EDGELITE_DATABASE__SQLITE_PATH=data/edgelite.db

# ============================================
# InfluxDB 时序数据库
# 必须配置！否则时序数据存储功能不可用
# 生成 Token 命令: python -c "import secrets; print(secrets.token_urlsafe(48))"
# ============================================
EDGELITE_INFLUXDB__URL=http://localhost:8086
EDGELITE_INFLUXDB__TOKEN=K7mX2pR9vW4yH1jM6cF0gL3pS8tV2wZ5bD9mJ4qR7uX0yA3cE6hK9lN2pR5tV8wB1dG4jM7qS0u
EDGELITE_INFLUXDB__ORG=edgelite
EDGELITE_INFLUXDB__BUCKET=edgelite

# ============================================
# MQTT 配置
# ============================================
EDGELITE_MQTT__BROKER=localhost
EDGELITE_MQTT__PORT=1883
# EDGELITE_MQTT__USERNAME=
# EDGELITE_MQTT__PASSWORD=

# ============================================
# 安全配置（生产环境必须修改！）
# 未配置时系统将自动生成随机密钥（重启后失效）
# 生成命令: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ============================================
EDGELITE_SECURITY__SECRET_KEY=c8nSH3RdgLhrlVIMi0SQOo-9C64wFnDlpE9AxZaf8oI
# EDGELITE_SECURITY__ACCESS_TOKEN_EXPIRE_MINUTES=30
# EDGELITE_SECURITY__REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# 可选服务开关
# ============================================
# EDGELITE_SIMULATOR__AUTO_CREATE=true
# EDGELITE_PREPROCESS__ENABLED=false
# EDGELITE_MQTT_SERVER__ENABLED=false
# EDGELITE_MODBUS_SLAVE__ENABLED=false
# EDGELITE_SERIAL_BRIDGE__ENABLED=false
# EDGELITE_GRAFANA__ENABLED=false
# EDGELITE_GRAFANA__URL=http://localhost:3001
# EDGELITE_MCP_SERVER__ENABLED=false
# EDGELITE_OTA_UPDATE_URL=

# ============================================
# AI推理引擎配置
# 默认启用，需安装 onnxruntime: pip install ".[ai]"
# ============================================
# EDGELITE_AI_INFERENCE__ENABLED=true
# EDGELITE_AI_INFERENCE__MODELS_DIR=

# ============================================
# 视频服务配置
# ============================================
# EDGELITE_VIDEO__PYGBSENTRY__ENDPOINT=
# EDGELITE_VIDEO__PYGBSENTRY__API_KEY=

# ============================================
# 日志配置
# ============================================
EDGELITE_LOGGING__LEVEL=INFO
