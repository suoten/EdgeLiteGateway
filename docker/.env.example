# EdgeLiteGateway Docker Compose 环境变量示例
# 复制此文件为 .env 并修改实际值

# ============================================
# InfluxDB 配置
# ============================================
INFLUXDB_TOKEN=your-secure-influxdb-token-change-me
INFLUXDB_PASSWORD=your-secure-admin-password

# ============================================
# EdgeLiteGateway 安全配置
# ============================================
# 生成命令: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-jwt-secret-key-at-least-32-chars
