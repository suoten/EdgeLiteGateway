# EdgeLiteGateway Docker Compose 环境变量
# 复制此文件为 .env 即可使用：cp .env.example .env
# 生产环境请替换为安全随机值！

# ============================================
# InfluxDB 配置
# 生成安全 Token: python -c "import secrets; print(secrets.token_urlsafe(48))"
# ============================================
INFLUXDB_TOKEN=<your-influxdb-token-here>
INFLUXDB_PASSWORD=<your-influxdb-password-here>

# ============================================
# EdgeLiteGateway 安全配置
# 生产环境请替换为安全随机值
# ============================================
SECRET_KEY=<your-secret-key-here>

# ============================================
# MQTT 鉴权配置（mosquitto 容器必备）
# 用于生成 /mosquitto/config/passwd 中 edgelite 用户的密码
# 同时映射到 edgelite 服务的 EDGELITE_MQTT__PASSWORD，二者必须一致
# 生成命令: python -c "import secrets; print(secrets.token_urlsafe(16))"
# 部署前必须设置强密码（至少12位，含大小写字母、数字、特殊字符）
# ============================================
MQTT_PASSWORD=<必须修改为强密码>

# ============================================
# 加密与密钥配置（生产环境必填！缺失将拒绝启动）
# 用于敏感凭据加密（Fernet/AES-GCM）的密钥派生
# ============================================
# 主密钥：用于派生 Fernet 加密密钥，未配置时生产环境将拒绝启动
# 生成命令: openssl rand -hex 32
#        或 python -c "import secrets; print(secrets.token_hex(32))"
EDGELITE_MASTER_KEY=<your-master-key-hex-32>
# KDF 盐值：base64 编码的 16 字节随机值，用于 PBKDF2 密钥派生
# 生成命令: python -c "import base64,os; print(base64.b64encode(os.urandom(16)).decode())"
EDGELITE_KDF_SALT=<your-base64-kdf-salt>
# 允许不安全 TLS（cert_reqs=none）：仅用于自签名证书测试环境，生产环境切勿启用
# EDGELITE_ALLOW_INSECURE_TLS=0

# ============================================
# 管理员账号配置
# ADMIN_PASSWORD: admin 初始密码（首次初始化创建 admin 时使用）
# ADMIN_RESET_PASSWORD: 设为 true 可强制重置已存在 admin 的密码（一次性，重置后建议改回 false）
# ============================================
# 安全警告：部署前必须修改为强密码！切勿使用占位符或默认值部署到生产环境！
# 强密码要求：至少12位，含大小写字母、数字、特殊字符
# 生成命令: python -c "import secrets; print(secrets.token_urlsafe(16))"
ADMIN_PASSWORD=<必须修改为强密码>
# 部署前必须设置强密码（至少12位，含大小写字母、数字、特殊字符）
ADMIN_RESET_PASSWORD=false

# ============================================
# Grafana 监控面板配置（monitoring profile 启用时必填）
# 启动监控栈: docker compose --profile monitoring up -d
# ============================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<必须修改为强密码>

# ============================================
# Alertmanager 告警通知配置（monitoring profile 启用时可选）
# 用于邮件告警通知，未配置时告警仅发送到 EdgeLite Webhook
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_FROM=alertmanager@example.com
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=admin@example.com