# EdgeLiteGateway Docker Compose 环境变量
# 复制此文件为 .env 即可使用：cp .env.example .env
# 生产环境请替换为安全随机值！

# ============================================
# InfluxDB 配置
# 生成安全 Token: python -c "import secrets; print(secrets.token_urlsafe(48))"
# ============================================
INFLUXDB_TOKEN=edgelite-dev-token-change-in-production
INFLUXDB_PASSWORD=edgelite-admin-2024

# ============================================
# EdgeLiteGateway 安全配置
# 生成安全密钥: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ============================================
SECRET_KEY=edgelite-dev-secret-key-change-in-production
