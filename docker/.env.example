# EdgeLiteGateway Docker Compose 环境变量示例
# 复制此文件为 .env 并修改实际值
# cp .env.example .env

# ============================================
# InfluxDB 配置（必填）
# 生成 Token: python -c "import secrets; print(secrets.token_urlsafe(48))"
# ============================================
INFLUXDB_TOKEN=your-secure-influxdb-token-here
INFLUXDB_PASSWORD=your-secure-admin-password-here

# ============================================
# EdgeLiteGateway 安全配置（必填）
# 生成命令: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ============================================
SECRET_KEY=your-jwt-secret-key-at-least-32-chars-here
